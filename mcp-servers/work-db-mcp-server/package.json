{
  "name": "work-db-mcp-server",
  "version": "1.0.0",
  "private": true,
  "description": "MCP server exposing work-db's tickets API as tools",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
